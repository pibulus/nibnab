<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
    Dev / DMG (Developer ID) entitlements: deliberately NOT sandboxed.
    The Accessibility API (selection auto-capture) is unavailable to
    sandboxed apps, and unsandboxed builds keep reading the existing data at
    ~/Library/Application Support/com.pibulus.nibnab/.
    The Mac App Store build uses NibNab.entitlements (sandboxed,
    clipboard-capture only) instead.
-->
<dict/>
</plist>
